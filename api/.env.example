# --- Core ---
ENVIRONMENT=development
# SQLite for local dev; Postgres (RDS) in production
DATABASE_URL=sqlite:///./astrokarma.db

# Comma-separated list of allowed web origins (CORS)
CORS_ORIGINS=http://localhost:5173

# Local API port (the launcher runs uvicorn on this; 8000 is often taken)
API_PORT=8077

# --- Auth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=dev-secret-change-me

# --- AI (later phase) ---
ANTHROPIC_API_KEY=
