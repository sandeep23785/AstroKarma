# --- Core ---
ENVIRONMENT=development
# SQLite for local dev; Postgres (RDS) in production
DATABASE_URL=sqlite:///./astrokarma.db

# Comma-separated list of allowed web origins (CORS)
CORS_ORIGINS=http://localhost:5173

# Local API port (the launcher runs uvicorn on this; 8000 is often taken)
API_PORT=8077

# --- Auth / Google Drive ---
# From Google Cloud Console: enable the Google Drive API, create an OAuth
# "Web application" client, and add this redirect URI:
#   http://localhost:8077/api/drive/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8077/api/drive/callback
WEB_APP_URL=http://localhost:5173
JWT_SECRET=dev-secret-change-me

# --- AI (later phase) ---
ANTHROPIC_API_KEY=
